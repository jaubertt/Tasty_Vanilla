+        ItemGroupEvents.modifyEntriesEvent(ItemGroups.BUILDING_BLOCKS).register(fabricItemGroupEntries ->
+                fabricItemGroupEntries.add(ModBlocks.SALT_BLOCK));
+        ItemGroupEvents.modifyEntriesEvent(ItemGroups.BUILDING_BLOCKS).register(fabricItemGroupEntries ->
+                fabricItemGroupEntries.add(ModBlocks.SUGAR_BLOCK));
+
+    }
